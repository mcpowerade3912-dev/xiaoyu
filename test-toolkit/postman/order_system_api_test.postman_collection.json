			"name": "07-接口兼容性验证",
			"description": "验证统一返回格式、状态码规范",
			"item": [
				{
					"name": "TC-API-001 返回格式验证-code字段存在",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/goods/page?pageNum=1&pageSize=5",
							"host": ["{{baseUrl}}"],
							"path": ["goods", "page"],
							"query": [
								{ "key": "pageNum", "value": "1" },
								{ "key": "pageSize", "value": "5" }
							]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('返回格式包含code和msg字段', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('code');",
									"    pm.expect(jsonData).to.have.property('msg');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "TC-API-002 返回格式验证-登录返回token结构",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/user/login",
							"host": ["{{baseUrl}}"],
							"path": ["user", "login"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('登录返回完整字段', function() {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.code).to.eql('200');",
									"    pm.expect(jsonData.data).to.have.property('token');",
									"    pm.expect(jsonData.data).to.have.property('userId');",
									"    pm.expect(jsonData.data).to.have.property('username');",
									"    pm.expect(jsonData.data).to.have.property('role');",
									"});"
								]
							}
						}
					]
				},
